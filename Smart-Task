"""
smart_task_manager.py

A native desktop application for students to track and manage academic deadlines.
Utilizes a Model-View-Controller (MVC) architecture, SQLite for local persistence,
and CustomTkinter for a modern, high-visibility user interface.
"""

import customtkinter as ctk
import tkinter as tk
from tkinter import ttk, messagebox
import sqlite3
from datetime import datetime


class TaskModel:
    """
    Manages the SQLite database connection and all data operations.

    Responsible for creating the schema, inserting, updating, deleting,
    and retrieving task records. Acts as the Model in the MVC architecture,
    completely isolated from the UI logic.
    
    Attributes:
        conn (sqlite3.Connection): The active connection to the SQLite database.
    """

    def __init__(self, db_name="smart_tasks.db"):
        """
        Initialize the database connection and ensure the schema exists.

        Args:
            db_name (str): The filename for the SQLite database. Defaults to 'smart_tasks.db'.
        """
        self.conn = sqlite3.connect(db_name)
        self.create_table()

    def create_table(self):
        """Create the tasks table if it does not already exist in the database."""
        cursor = self.conn.cursor()
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS tasks (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                task_name TEXT NOT NULL,
                subject TEXT,
                deadline TEXT,
                priority TEXT,
                status TEXT
            )
        ''')
        self.conn.commit()

    def add_task(self, name, subject, deadline, priority, status):
        """
        Insert a new task record into the database.

        Args:
            name (str): The title of the task.
            subject (str): The academic subject or module.
            deadline (str): The due date in 'YYYY-MM-DD' ISO format.
            priority (str): Urgency level ('Low', 'Medium', 'High').
            status (str): Current state ('Pending', 'Completed').
        """
        cursor = self.conn.cursor()
        cursor.execute('''
            INSERT INTO tasks (task_name, subject, deadline, priority, status)
            VALUES (?, ?, ?, ?, ?)
        ''', (name, subject, deadline, priority, status))
        self.conn.commit()

    def update_task(self, task_id, name, subject, deadline, priority, status):
        """
        Update an existing task record by its unique ID.

        Args:
            task_id (int): The primary key of the task to update.
            name (str): The updated task title.
            subject (str): The updated academic subject.
            deadline (str): The updated due date in 'YYYY-MM-DD' ISO format.
            priority (str): The updated urgency level.
            status (str): The updated completion state.
        """
        cursor = self.conn.cursor()
        cursor.execute('''
            UPDATE tasks SET task_name=?, subject=?, deadline=?, priority=?, status=?
            WHERE id=?
        ''', (name, subject, deadline, priority, status, task_id))
        self.conn.commit()

    def delete_task(self, task_id):
        """
        Remove a task from the database by its unique ID.

        Args:
            task_id (int): The primary key of the task to delete.
        """
        cursor = self.conn.cursor()
        cursor.execute("DELETE FROM tasks WHERE id=?", (task_id,))
        self.conn.commit()

    def get_tasks(self, status_filter="All", priority_filter="All", search_term="", sort_by="Deadline"):
        """
        Retrieve a filtered and sorted list of tasks from the database.

        Applies SQL CASE weighting to sort text-based priorities logically 
        rather than alphabetically.

        Args:
            status_filter (str): Filter by 'Pending', 'Completed', or 'All'.
            priority_filter (str): Filter by 'High', 'Medium', 'Low', or 'All'.
            search_term (str): Partial text match for the task name.
            sort_by (str): The column/logic to order the results by.

        Returns:
            list[tuple]: A list of tuples containing the matched task records.
        """
        cursor = self.conn.cursor()
        query = "SELECT * FROM tasks WHERE 1=1"
        params = []
        
        if status_filter != "All":
            query += " AND status=?"
            params.append(status_filter)
        if priority_filter != "All":
            query += " AND priority=?"
            params.append(priority_filter)
        if search_term:
            query += " AND task_name LIKE ?"
            params.append(f"%{search_term}%")
            
        if sort_by == "Priority (High to Low)":
            query += " ORDER BY CASE priority WHEN 'High' THEN 3 WHEN 'Medium' THEN 2 WHEN 'Low' THEN 1 END DESC, deadline ASC"
        elif sort_by == "Priority (Low to High)":
            query += " ORDER BY CASE priority WHEN 'High' THEN 3 WHEN 'Medium' THEN 2 WHEN 'Low' THEN 1 END ASC, deadline ASC"
        else:
            query += " ORDER BY deadline ASC"
            
        cursor.execute(query, params)
        return cursor.fetchall()



