def add_task(self):
        """Extract validated inputs from the View and command the Model to insert a task."""
        name = self.view.ent_name.get().strip().title()
        subject = self.view.ent_subject.get().strip().title()
        deadline = self.view.get_selected_date_iso()
        priority = self.view.cbo_priority.get()
        status = self.view.cbo_status.get()

        if not name or not deadline:
            messagebox.showerror("Error", "Name and Date fields must be completely filled out!")
            return
        if not self.validate_date(deadline):
            messagebox.showerror("Error", "Invalid date selected (e.g., February 31st)!")
            return

        self.model.add_task(name, subject, deadline, priority, status)
        self.view.clear_inputs()
        self.refresh_list()

    def update_task(self):
        """Extract updated inputs from the View and command the Model to save edits."""
        selected = self.view.tree.selection()
        if not selected:
            messagebox.showwarning("Warning", "Double-click a task in the list first to select it.")
            return

        task_id = self.view.tree.item(selected[0])['values'][0]
        name = self.view.ent_name.get().strip().title()
        subject = self.view.ent_subject.get().strip().title()
        deadline = self.view.get_selected_date_iso()
        priority = self.view.cbo_priority.get()
        status = self.view.cbo_status.get()

        if not name or not self.validate_date(deadline):
            messagebox.showerror("Error", "Valid Name and Date required!")
            return

        self.model.update_task(task_id, name, subject, deadline, priority, status)
        self.view.clear_inputs()
        self.refresh_list()

    def delete_task(self):
        """Prompt for user confirmation, then command the Model to delete the selected task."""
        selected = self.view.tree.selection()
        if not selected:
            messagebox.showwarning("Warning", "Select a task to delete.")
            return

        if messagebox.askyesno("Confirm", "Are you sure you want to delete this task?"):
            task_id = self.view.tree.item(selected[0])['values'][0]
            self.model.delete_task(task_id)
            self.refresh_list()
